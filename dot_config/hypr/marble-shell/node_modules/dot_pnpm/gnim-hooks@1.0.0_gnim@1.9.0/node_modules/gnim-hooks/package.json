{
    "name": "gnim-hooks",
    "version": "1.0.0",
    "type": "module",
    "author": "Aylur",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Aylur/gnim-hooks.git"
    },
    "funding": {
        "type": "kofi",
        "url": "https://ko-fi.com/aylur"
    },
    "devDependencies": {
        "@eslint/js": "latest",
        "@girs/gjs": "latest",
        "@girs/gtk-4.0": "latest",
        "eslint": "latest",
        "typescript": "latest",
        "typescript-eslint": "latest"
    },
    "scripts": {
        "lint": "eslint . --fix",
        "build": "true"
    },
    "peerDependencies": {
        "gnim": "^1.9.0"
    },
    "exports": {
        ".": "./src/index.ts",
        "./gtk4": "./src/index.ts"
    },
    "files": [
        "src"
    ],
    "engines": {
        "gjs": ">=1.79.0"
    },
    "keywords": [
        "GJS",
        "Gnome",
        "GTK",
        "JSX"
    ],
    "prettier": {
        "semi": false,
        "tabWidth": 4,
        "quoteProps": "consistent",
        "trailingComma": "all",
        "printWidth": 100,
        "experimentalTernaries": false,
        "overrides": [
            {
                "files": "**/*.md",
                "options": {
                    "tabWidth": 2,
                    "printWidth": 80,
                    "proseWrap": "always"
                }
            }
        ]
    }
}
